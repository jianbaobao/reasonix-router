#!/bin/sh
# ============================================================
#  S01overlay — OverlayFS 持久化存储
#  检测可用磁盘分区并设置 overlay 根文件系统覆盖层
#  使 /etc 配置修改重启后保持
# ============================================================

OVERLAY_BASE="/overlay"
UPPER_DIR="$OVERLAY_BASE/upper"
WORK_DIR="$OVERLAY_BASE/work"
MOUNT_FILE="/var/run/overlay_device"

echo "  Checking for persistent storage..."

# 等待存储设备就绪 (裸机需要时间探测)
sleep 1

# 扫描所有分区设备 (SATA/NVMe/USB/MMC/VirtIO)
BLOCK_DEVICES=""
for dev in /dev/[svh]d[a-z][0-9] /dev/nvme[0-9]n[0-9]p[0-9] /dev/mmcblk[0-9]p[0-9] \
           /dev/xvd[a-z][0-9] /dev/vd[a-z][0-9] 2>/dev/null; do
    [ -b "$dev" ] && BLOCK_DEVICES="$BLOCK_DEVICES $dev"
done

# 按优先级排序: NVMe > SATA > VirtIO > MMC
SORTED=""
for pattern in "nvme[0-9]" "[sh]d[a-z]" "vd[a-z]" "xvd[a-z]" "mmcblk[0-9]"; do
    for dev in $BLOCK_DEVICES; do
        base=$(basename "$dev")
        echo "$base" | grep -qE "$pattern" && SORTED="$SORTED $dev"
    done
done
BLOCK_DEVICES="$SORTED"

FOUND=0
for device in $BLOCK_DEVICES; do
    # 跳过已挂载的设备
    mount | grep -q "$device" && continue

    echo "  Probing $device..."

    # 尝试挂载 (只读检测)
    FSTYPE=""
    FSTYPE=$(blkid "$device" 2>/dev/null | sed -n 's/.*TYPE="\([^"]*\)".*/\1/p')
    [ -z "$FSTYPE" ] && FSTYPE=$(df -T "$device" 2>/dev/null | tail -1 | awk '{print $2}')

    case "$FSTYPE" in
        ext4|ext3|ext2|btrfs|xfs|f2fs)
            # 可写文件系统: 挂载为 overlay
            mkdir -p "$OVERLAY_BASE/disk" 2>/dev/null
            if mount -t "$FSTYPE" "$device" "$OVERLAY_BASE/disk" 2>/dev/null; then
                echo "  ✅ Found $FSTYPE partition: $device"

                # 确保 upper/work 目录存在
                mkdir -p "$UPPER_DIR/etc" "$WORK_DIR" 2>/dev/null

                # 尝试挂载 OverlayFS
                if mount -t overlay overlay -o \
                    lowerdir=/,upperdir=$UPPER_DIR,workdir=$WORK_DIR \
                    /mnt/root 2>/dev/null; then
                    echo "  ✅ OverlayFS active: $device"
                    echo "$device" > "$MOUNT_FILE"
                    FOUND=1
                    break
                else
                    # 内核可能不支持 OverlayFS, 直接绑定挂载 /etc
                    if mount --bind "$OVERLAY_BASE/disk/etc" /etc 2>/dev/null; then
                        echo "  ✅ Bind-mounted /etc from $device (no overlay)"
                        echo "$device" > "$MOUNT_FILE"
                        FOUND=1
                        break
                    fi
                    umount "$OVERLAY_BASE/disk" 2>/dev/null
                fi
            fi
            ;;
    esac
done

if [ "$FOUND" -eq 0 ]; then
    echo "  No persistent storage found. Running in RAM-only mode."
else
    echo "  Persistent storage ready. Configs will survive reboot."
fi
